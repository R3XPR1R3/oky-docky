{
  "fields": [
    {
      "key": "filing_self",
      "type": "checkbox",
      "required": false,
      "label": "I am submitting Form 14039 for myself"
    },
    {
      "key": "responding_to_notice",
      "type": "checkbox",
      "required": false,
      "routing": true,
      "label": "I am submitting Form 14039 in response to an IRS notice or letter"
    },
    {
      "key": "filing_dependent",
      "type": "checkbox",
      "required": false,
      "label": "I am submitting Form 14039 for my dependent child or dependent relative"
    },
    {
      "key": "filing_other_person",
      "type": "checkbox",
      "required": false,
      "label": "I am submitting Form 14039 for another living or deceased person"
    },
    {
      "key": "notice_letter",
      "type": "text",
      "required": false,
      "label": "What was the IRS letter or notice number?",
      "placeholder": "CP01A, LTR 5071C, etc.",
      "helpText": "Look at the top-right corner of the IRS letter. It should have a number. If you can't find it, just skip this.",
      "visible_when": {
        "responding_to_notice": [
          true
        ]
      }
    },
    {
      "key": "tax_return_fraud",
      "type": "checkbox",
      "required": false,
      "label": "Someone used my information to fraudulently file a federal tax return"
    },
    {
      "key": "spouse_victim",
      "type": "checkbox",
      "required": false,
      "label": "My spouse is also a victim",
      "visible_when": {"tax_return_fraud": [true]}
    },
    {
      "key": "dependent_claim",
      "type": "checkbox",
      "required": false,
      "label": "I or my dependent was fraudulently or incorrectly claimed as a dependent"
    },
    {
      "key": "employment_misuse",
      "type": "checkbox",
      "required": false,
      "label": "My SSN or ITIN was fraudulently used for employment purposes"
    },
    {
      "key": "theft_details",
      "type": "text",
      "required": false,
      "label": "Can you tell us more about what happened?",
      "placeholder": "I noticed a W-2 from a company I never worked for...",
      "helpText": "Any details help — when you noticed, what was wrong, anything unusual. This helps the IRS investigate."
    },
    {
      "key": "last_tax_year",
      "type": "text",
      "required": true,
      "label": "What tax year was affected?",
      "placeholder": "2025",
      "helpText": "The most recent year when someone messed with your taxes. Usually last year.",
      "maxLength": 4
    },
    {
      "key": "additional_years",
      "type": "text",
      "required": false,
      "label": "Were other years affected too?",
      "placeholder": "2024, 2023",
      "helpText": "If this happened over multiple years, list them separated by commas. Leave blank if it was just one year."
    },
    {
      "key": "had_no_filing",
      "type": "checkbox",
      "required": false,
      "label": "I wasn't even required to file taxes that year",
      "helpText": "Check this if you didn't need to file a tax return for the year(s) listed above — for example, if you didn't work or earned too little."
    },
    {
      "key": "name_on_return",
      "type": "text",
      "required": false,
      "label": "Do you know the name the thief used?",
      "placeholder": "Jon Doe",
      "helpText": "If you know a different name appeared on the fake return, enter it here. Otherwise skip this."
    },
    {
      "key": "first_name",
      "type": "text",
      "required": true,
      "label": "Now let's get your info — what is your first name?",
      "placeholder": "Jane",
      "helpText": "Your legal first name as it appears on your tax return."
    },
    {
      "key": "last_name",
      "type": "text",
      "required": true,
      "label": "Last name?",
      "placeholder": "Williams"
    },
    {
      "key": "middle_initial",
      "type": "text",
      "required": false,
      "label": "Middle initial? (optional)",
      "placeholder": "M",
      "inputMask": "L",
      "maxLength": 1
    },
    {
      "key": "tin",
      "type": "text",
      "required": true,
      "label": "What is the SSN or ITIN that was misused?",
      "placeholder": "123-45-6789",
      "helpText": "The 9-digit number that belongs to you — the one the thief used.",
      "inputMask": "DDD-DD-DDDD",
      "maxLength": 11
    },
    {
      "key": "current_mailing_address",
      "type": "text",
      "required": true,
      "label": "What is your current street address?",
      "placeholder": "123 Main Street, Apt 4",
      "helpText": "Where you currently live and get your mail."
    },
    {
      "key": "current_address_unit",
      "type": "text",
      "required": false,
      "label": "Apartment, room, or suite number?",
      "placeholder": "Apt 4"
    },
    {
      "key": "city",
      "type": "text",
      "required": true,
      "label": "City?",
      "placeholder": "Oklahoma City"
    },
    {
      "key": "state",
      "type": "text",
      "required": true,
      "label": "State? (2 letters)",
      "placeholder": "OK",
      "helpText": "Two-letter state code, like TX, NY, CA, OK.",
      "inputMask": "LL",
      "maxLength": 2
    },
    {
      "key": "zip_first5",
      "type": "text",
      "required": true,
      "label": "ZIP code?",
      "placeholder": "73102",
      "inputMask": "DDDDD",
      "maxLength": 5
    },
    {
      "key": "zip_last4",
      "type": "text",
      "required": false,
      "label": "ZIP+4? (optional)",
      "placeholder": "0002",
      "helpText": "The extra 4 digits after your ZIP. Skip if you don't know.",
      "inputMask": "DDDD",
      "maxLength": 4
    },
    {
      "key": "has_previous_address",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "Did you recently move?",
      "helpText": "If your address was different when the identity theft happened, we need that old address too.",
      "options": [
        {
          "value": "no",
          "label": "No, same address"
        },
        {
          "value": "yes",
          "label": "Yes, I moved"
        }
      ]
    },
    {
      "key": "prev_address",
      "type": "text",
      "required": true,
      "label": "What was your old street address?",
      "placeholder": "456 Oak Avenue",
      "visible_when": {
        "has_previous_address": [
          "yes"
        ]
      }
    },
    {
      "key": "prev_address_unit",
      "type": "text",
      "required": false,
      "label": "Old apartment, room, or suite number?",
      "placeholder": "Suite 200",
      "visible_when": {
        "has_previous_address": [
          "yes"
        ]
      }
    },
    {
      "key": "prev_city",
      "type": "text",
      "required": true,
      "label": "Old city?",
      "placeholder": "Dallas",
      "visible_when": {
        "has_previous_address": [
          "yes"
        ]
      }
    },
    {
      "key": "prev_state",
      "type": "text",
      "required": true,
      "label": "Old state? (2 letters)",
      "placeholder": "TX",
      "visible_when": {
        "has_previous_address": [
          "yes"
        ]
      },
      "inputMask": "LL",
      "maxLength": 2
    },
    {
      "key": "prev_zip_first5",
      "type": "text",
      "required": true,
      "label": "Old ZIP code?",
      "placeholder": "75201",
      "visible_when": {
        "has_previous_address": [
          "yes"
        ]
      },
      "inputMask": "DDDDD",
      "maxLength": 5
    },
    {
      "key": "prev_zip_last4",
      "type": "text",
      "required": false,
      "label": "Old ZIP+4? (optional)",
      "placeholder": "0003",
      "visible_when": {
        "has_previous_address": [
          "yes"
        ]
      },
      "inputMask": "DDDD",
      "maxLength": 4
    },
    {
      "key": "phone_home",
      "type": "text",
      "required": false,
      "label": "Home phone number? (optional)",
      "placeholder": "(405) 555-1234",
      "helpText": "A landline number where the IRS can reach you."
    },
    {
      "key": "phone_cell",
      "type": "text",
      "required": false,
      "label": "Cell phone number? (optional)",
      "placeholder": "(405) 555-5678",
      "helpText": "A mobile number where the IRS can reach you."
    },
    {
      "key": "best_time",
      "type": "text",
      "required": false,
      "label": "Best time to call? (optional)",
      "placeholder": "9 AM – 5 PM",
      "helpText": "When should they try calling?"
    },
    {
      "key": "language",
      "type": "radio",
      "required": true,
      "label": "What language do you prefer?",
      "helpText": "The IRS will try to communicate with you in this language.",
      "options": [
        {
          "value": "english",
          "label": "English"
        },
        {
          "value": "spanish",
          "label": "Spanish"
        },
        {
          "value": "other",
          "label": "Another language"
        }
      ]
    },
    {
      "key": "language_other",
      "type": "text",
      "required": true,
      "label": "Which language?",
      "placeholder": "Mandarin, Vietnamese, Korean, etc.",
      "visible_when": {
        "language": [
          "other"
        ]
      }
    },
    {
      "key": "signature",
      "type": "signature",
      "required": true,
      "label": "Sign your name",
      "helpText": "By signing, you swear under penalty of perjury that everything you wrote above is true. You can type your name or draw your signature."
    },
    {
      "key": "filing_for",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "Who is filling out this form?",
      "helpText": "If a lawyer, enrolled agent, parent, or guardian is doing this for you, pick the second option.",
      "options": [
        {
          "value": "myself",
          "label": "I'm doing it myself"
        },
        {
          "value": "representative",
          "label": "Someone else is doing it for me (attorney, EA, parent, etc.)"
        }
      ]
    },
    {
      "key": "rep_first_name",
      "type": "text",
      "required": true,
      "label": "Their first name?",
      "placeholder": "John",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      }
    },
    {
      "key": "rep_last_name",
      "type": "text",
      "required": true,
      "label": "Their last name?",
      "placeholder": "Smith",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      }
    },
    {
      "key": "rep_middle_initial",
      "type": "text",
      "required": false,
      "label": "Their middle initial? (optional)",
      "placeholder": "A",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      },
      "inputMask": "L",
      "maxLength": 1
    },
    {
      "key": "rep_reason",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "Why is this person authorized to complete the form?",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      },
      "options": [
        {
          "value": "surviving_spouse",
          "label": "The taxpayer is deceased and I am the surviving spouse"
        },
        {
          "value": "court_appointed_rep",
          "label": "The taxpayer is deceased and I am the court-appointed or certified personal representative"
        },
        {
          "value": "uncertified_rep",
          "label": "The taxpayer is deceased and a court-appointed representative has not been appointed"
        },
        {
          "value": "conservator_or_poa",
          "label": "The taxpayer cannot complete the form and I am a conservator or authorized by Form 2848 or 56"
        },
        {
          "value": "dependent_relative",
          "label": "The person is my dependent child or dependent relative"
        }
      ]
    },
    {
      "key": "uncertified_relationship",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "What is the representative's relationship to the deceased taxpayer?",
      "visible_when": {
        "filing_for": [
          "representative"
        ],
        "rep_reason": [
          "uncertified_rep"
        ]
      },
      "options": [
        {
          "value": "child",
          "label": "Child"
        },
        {
          "value": "parent_guardian",
          "label": "Parent or legal guardian"
        },
        {
          "value": "other",
          "label": "Other"
        }
      ]
    },
    {
      "key": "uncertified_other_explain",
      "type": "text",
      "required": true,
      "label": "Describe the relationship to the deceased taxpayer",
      "placeholder": "Sibling, domestic partner, etc.",
      "visible_when": {
        "filing_for": [
          "representative"
        ],
        "rep_reason": [
          "uncertified_rep"
        ],
        "uncertified_relationship": [
          "other"
        ]
      }
    },
    {
      "key": "dependent_authority",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "What authority does the representative have for the dependent?",
      "visible_when": {
        "filing_for": [
          "representative"
        ],
        "rep_reason": [
          "dependent_relative"
        ]
      },
      "options": [
        {"value": "parent_guardian", "label": "Parent or legal guardian"},
        {"value": "fiduciary", "label": "Fiduciary under IRS Form 56"},
        {"value": "power_of_attorney", "label": "Power of Attorney"},
        {"value": "other", "label": "Other"}
      ]
    },
    {
      "key": "dependent_authority_other",
      "type": "text",
      "required": true,
      "label": "Describe the representative's authority",
      "placeholder": "Describe the legal authority",
      "visible_when": {
        "filing_for": [
          "representative"
        ],
        "rep_reason": [
          "dependent_relative"
        ],
        "dependent_authority": [
          "other"
        ]
      }
    },
    {
      "key": "rep_address",
      "type": "text",
      "required": true,
      "label": "Their address?",
      "placeholder": "789 Attorney Ave, Suite 100, Chicago, IL 60601",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      }
    },
    {
      "key": "rep_phone",
      "type": "text",
      "required": true,
      "label": "Their phone number?",
      "placeholder": "(312) 555-9999",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      }
    },
    {
      "key": "rep_caf",
      "type": "text",
      "required": false,
      "label": "Their CAF number? (optional)",
      "placeholder": "1234567890",
      "helpText": "Centralized Authorization File number. Your tax preparer or attorney will know this. Skip if they don't have one.",
      "visible_when": {
        "filing_for": [
          "representative"
        ]
      }
    }
  ],
  "transforms": [
    {
      "type": "copy",
      "from": "phone_cell",
      "to": "phone_home",
      "if_empty": true
    },
    {
      "type": "auto_date",
      "field": "date_signed",
      "format": "MM/DD/YYYY"
    }
  ]
}
