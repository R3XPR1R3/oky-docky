{
  "fields": [
    {
      "key": "first_name",
      "type": "text",
      "required": true,
      "label": "What is your first name?",
      "placeholder": "Jane",
      "helpText": "Your legal first name as it appears on your tax return."
    },
    {
      "key": "last_name",
      "type": "text",
      "required": true,
      "label": "What is your last name?",
      "placeholder": "Williams"
    },
    {
      "key": "middle_initial",
      "type": "text",
      "required": false,
      "label": "Middle initial? (optional)",
      "placeholder": "M"
    },
    {
      "key": "tin",
      "type": "text",
      "required": true,
      "label": "What SSN or ITIN was stolen or misused?",
      "placeholder": "123-45-6789",
      "helpText": "Enter the Social Security Number or Individual Taxpayer ID that someone used without your permission."
    },
    {
      "key": "current_mailing_address",
      "type": "text",
      "required": true,
      "label": "What is your current street address?",
      "placeholder": "123 Main Street, Apt 4",
      "helpText": "Where you currently live and get your mail."
    },
    {
      "key": "city",
      "type": "text",
      "required": true,
      "label": "City?",
      "placeholder": "Oklahoma City"
    },
    {
      "key": "state",
      "type": "text",
      "required": true,
      "label": "State? (2 letters)",
      "placeholder": "OK",
      "helpText": "Two-letter state code, like TX, NY, CA, OK."
    },
    {
      "key": "zip_first5",
      "type": "text",
      "required": true,
      "label": "ZIP code?",
      "placeholder": "73102"
    },
    {
      "key": "zip_last4",
      "type": "text",
      "required": false,
      "label": "ZIP+4 extension? (optional)",
      "placeholder": "0002",
      "helpText": "The extra 4 digits after your ZIP code. Skip this if you don't know it."
    },
    {
      "key": "has_previous_address",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "Did you recently move?",
      "helpText": "If you had a different address when the identity theft happened, we need that old address too.",
      "options": [
        { "value": "no", "label": "No, I've been at the same address" },
        { "value": "yes", "label": "Yes, I moved — my old address was different" }
      ]
    },
    {
      "key": "prev_address",
      "type": "text",
      "required": true,
      "label": "What was your old street address?",
      "placeholder": "456 Oak Avenue",
      "visible_when": { "has_previous_address": ["yes"] }
    },
    {
      "key": "prev_city",
      "type": "text",
      "required": true,
      "label": "Old city?",
      "placeholder": "Dallas",
      "visible_when": { "has_previous_address": ["yes"] }
    },
    {
      "key": "prev_state",
      "type": "text",
      "required": true,
      "label": "Old state? (2 letters)",
      "placeholder": "TX",
      "visible_when": { "has_previous_address": ["yes"] }
    },
    {
      "key": "prev_zip_first5",
      "type": "text",
      "required": true,
      "label": "Old ZIP code?",
      "placeholder": "75201",
      "visible_when": { "has_previous_address": ["yes"] }
    },
    {
      "key": "prev_zip_last4",
      "type": "text",
      "required": false,
      "label": "Old ZIP+4? (optional)",
      "placeholder": "0003",
      "visible_when": { "has_previous_address": ["yes"] }
    },
    {
      "key": "phone_home",
      "type": "text",
      "required": false,
      "label": "Home phone number? (optional)",
      "placeholder": "(405) 555-1234"
    },
    {
      "key": "phone_cell",
      "type": "text",
      "required": false,
      "label": "Cell phone number? (optional)",
      "placeholder": "(405) 555-5678"
    },
    {
      "key": "best_time",
      "type": "text",
      "required": false,
      "label": "Best time for the IRS to call you? (optional)",
      "placeholder": "9 AM – 5 PM",
      "helpText": "When would be a good time for them to reach you?"
    },
    {
      "key": "language",
      "type": "radio",
      "required": true,
      "label": "What language do you prefer?",
      "helpText": "The IRS will try to communicate with you in this language.",
      "options": [
        { "value": "english", "label": "English" },
        { "value": "spanish", "label": "Spanish" },
        { "value": "other", "label": "Another language" }
      ]
    },
    {
      "key": "language_other",
      "type": "text",
      "required": true,
      "label": "Which language?",
      "placeholder": "Mandarin, Vietnamese, Korean, etc.",
      "visible_when": { "language": ["other"] }
    },
    {
      "key": "reason_notice",
      "type": "checkbox",
      "required": false,
      "label": "I got a letter from the IRS saying someone used my info",
      "helpText": "Check this if the IRS sent you a notice or letter about suspicious activity."
    },
    {
      "key": "notice_letter",
      "type": "text",
      "required": false,
      "label": "What was the letter number? (if you have it)",
      "placeholder": "CP01A",
      "helpText": "Look at the top-right corner of the IRS letter. It should have a number like CP01A or LTR 5071C.",
      "visible_when": { "reason_notice": ["true"] }
    },
    {
      "key": "reason_rejected",
      "type": "checkbox",
      "required": false,
      "label": "My tax return was rejected because someone already filed using my info"
    },
    {
      "key": "reason_other_agency",
      "type": "checkbox",
      "required": false,
      "label": "Another agency (Social Security, state, etc.) told me about possible identity theft"
    },
    {
      "key": "reason_other",
      "type": "checkbox",
      "required": false,
      "label": "Other reason"
    },
    {
      "key": "theft_tax_return",
      "type": "checkbox",
      "required": false,
      "label": "Someone filed a fake tax return using my info",
      "helpText": "Now tell us what the thief actually did. Check everything that applies."
    },
    {
      "key": "theft_ssn_work",
      "type": "checkbox",
      "required": false,
      "label": "Someone used my SSN to get a job"
    },
    {
      "key": "theft_dependent",
      "type": "checkbox",
      "required": false,
      "label": "Someone claimed me (or my child) as a dependent on their taxes"
    },
    {
      "key": "theft_details",
      "type": "text",
      "required": false,
      "label": "Anything else you want to tell the IRS about what happened? (optional)",
      "placeholder": "Describe what happened...",
      "helpText": "Any details that might help them investigate — when you noticed, what happened, etc."
    },
    {
      "key": "last_tax_year",
      "type": "text",
      "required": true,
      "label": "What tax year was affected?",
      "placeholder": "2025",
      "helpText": "The most recent year when someone messed with your taxes. Usually last year."
    },
    {
      "key": "additional_years",
      "type": "text",
      "required": false,
      "label": "Were other years affected too? (optional)",
      "placeholder": "2024, 2023",
      "helpText": "If this happened over multiple years, list them separated by commas."
    },
    {
      "key": "had_no_filing",
      "type": "checkbox",
      "required": false,
      "label": "I wasn't even required to file taxes that year",
      "helpText": "Check this if you didn't need to file a tax return for the year(s) listed above."
    },
    {
      "key": "name_on_return",
      "type": "text",
      "required": false,
      "label": "Do you know the name the thief used? (optional)",
      "placeholder": "e.g., Jon Doe",
      "helpText": "If you know a different name was used on the fake return, enter it here."
    },
    {
      "key": "signature",
      "type": "signature",
      "required": true,
      "label": "Sign your name",
      "helpText": "By signing, you swear under penalty of perjury that everything you wrote is true. You can type your name or draw your signature."
    },
    {
      "key": "filing_for",
      "type": "radio",
      "required": true,
      "routing": true,
      "label": "Are you filling this out yourself?",
      "helpText": "If someone else (a lawyer, parent, guardian) is submitting this for you, pick the second option.",
      "options": [
        { "value": "myself", "label": "Yes, I'm doing this myself" },
        { "value": "representative", "label": "No, someone else is doing this for me" }
      ]
    },
    {
      "key": "rep_first_name",
      "type": "text",
      "required": true,
      "label": "Representative's first name?",
      "placeholder": "John",
      "visible_when": { "filing_for": ["representative"] }
    },
    {
      "key": "rep_last_name",
      "type": "text",
      "required": true,
      "label": "Representative's last name?",
      "placeholder": "Smith",
      "visible_when": { "filing_for": ["representative"] }
    },
    {
      "key": "rep_middle_initial",
      "type": "text",
      "required": false,
      "label": "Representative's middle initial? (optional)",
      "placeholder": "A",
      "visible_when": { "filing_for": ["representative"] }
    },
    {
      "key": "rep_address",
      "type": "text",
      "required": true,
      "label": "Representative's address?",
      "placeholder": "789 Attorney Ave, Suite 100, Chicago, IL 60601",
      "visible_when": { "filing_for": ["representative"] }
    },
    {
      "key": "rep_phone",
      "type": "text",
      "required": true,
      "label": "Representative's phone number?",
      "placeholder": "(312) 555-9999",
      "visible_when": { "filing_for": ["representative"] }
    },
    {
      "key": "rep_caf",
      "type": "text",
      "required": false,
      "label": "Representative's CAF number? (optional)",
      "placeholder": "1234567890",
      "helpText": "This is a special IRS authorization number. Skip it if you don't know what it is.",
      "visible_when": { "filing_for": ["representative"] }
    },
    {
      "key": "rep_relationship",
      "type": "radio",
      "required": true,
      "label": "What is this person's relationship to you?",
      "visible_when": { "filing_for": ["representative"] },
      "options": [
        { "value": "parent_guardian", "label": "My parent or legal guardian" },
        { "value": "fiduciary", "label": "Fiduciary (trustee, executor)" },
        { "value": "power_of_attorney", "label": "Power of Attorney" },
        { "value": "court_appointed", "label": "Court-appointed representative" },
        { "value": "other", "label": "Other" }
      ]
    },
    {
      "key": "rep_relationship_other",
      "type": "text",
      "required": true,
      "label": "Describe their relationship to you",
      "placeholder": "e.g., Enrolled Agent, Tax Preparer",
      "visible_when": { "filing_for": ["representative"], "rep_relationship": ["other"] }
    }
  ]
}
