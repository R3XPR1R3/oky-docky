      { "value": "30_days", "field": "TODO_term_30d", "export_on": "/4" }
    ]
  },

  "client_signature": {
    "type": "signature",
    "field": null,
    "page": 1,
    "rect": [65, 80, 300, 100]
  },

  "contractor_signature": {
    "type": "signature",
    "field": null,
    "page": 1,
    "rect": [320, 80, 560, 100]
  }
