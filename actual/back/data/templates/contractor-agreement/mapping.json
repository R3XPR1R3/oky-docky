  "start_date": {
    "type": "date_split",
    "fields": { "mm": "TODO_start_mm", "dd": "TODO_start_dd", "yyyy": "TODO_start_yyyy" }
  },

  "end_date": {
    "type": "date_split",
    "fields": { "mm": "TODO_end_mm", "dd": "TODO_end_dd", "yyyy": "TODO_end_yyyy" }
  },

  "sign_date": {
    "type": "date_split",
    "fields": { "mm": "TODO_sign_mm", "dd": "TODO_sign_dd", "yyyy": "TODO_sign_yyyy" }
  },

  "end_type": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "specific_date", "field": "TODO_end_specific", "export_on": "/1" },
      { "value": "ongoing", "field": "TODO_end_ongoing", "export_on": "/2" },
      { "value": "project_based", "field": "TODO_end_project", "export_on": "/3" }
    ]
  },

  "payment_type": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "hourly", "field": "TODO_pay_hourly", "export_on": "/1" },
      { "value": "fixed", "field": "TODO_pay_fixed", "export_on": "/2" },
      { "value": "monthly", "field": "TODO_pay_monthly", "export_on": "/3" }
    ]
  },

  "payment_schedule": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "weekly", "field": "TODO_sched_weekly", "export_on": "/1" },
      { "value": "biweekly", "field": "TODO_sched_biweekly", "export_on": "/2" },
      { "value": "monthly", "field": "TODO_sched_monthly", "export_on": "/3" },
      { "value": "upon_completion", "field": "TODO_sched_completion", "export_on": "/4" },
      { "value": "net_30", "field": "TODO_sched_net30", "export_on": "/5" },
      { "value": "net_60", "field": "TODO_sched_net60", "export_on": "/6" }
    ]
  },

  "invoice_method": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "email", "field": "TODO_invoice_email", "export_on": "/1" },
      { "value": "mail", "field": "TODO_invoice_mail", "export_on": "/2" },
      { "value": "portal", "field": "TODO_invoice_portal", "export_on": "/3" }
    ]
  },

  "work_ownership": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "client_owns", "field": "TODO_own_client", "export_on": "/1" },
      { "value": "contractor_licenses", "field": "TODO_own_license", "export_on": "/2" },
      { "value": "shared", "field": "TODO_own_shared", "export_on": "/3" }
    ]
  },

  "non_compete": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "no", "field": "TODO_nc_no", "export_on": "/1" },
      { "value": "yes", "field": "TODO_nc_yes", "export_on": "/2" }
    ]
  },

  "confidentiality": {
    "type": "checkbox",
    "field": "TODO_confidentiality_cb",
    "checked_value": "/Yes",
    "unchecked_value": "/Off"
  },

  "termination_notice": {
    "type": "radio_group",
    "off_value": "/Off",
    "choices": [
      { "value": "immediate", "field": "TODO_term_immediate", "export_on": "/1" },
