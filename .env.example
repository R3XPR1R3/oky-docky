# Copy this file to .env on the Pi and paste your Cloudflare named tunnel token.
# Do not commit the real token.
TUNNEL_TOKEN=

# Enables the cloudflared service so `docker compose up -d` starts backend,
# frontend, and the tunnel together.
COMPOSE_PROFILES=tunnel

# Public hostname configured in the Cloudflare tunnel dashboard.
PUBLIC_DOMAIN=barckhat.com
PUBLIC_URL=https://barckhat.com
