# Copy this file to .env on the Pi and paste your Cloudflare named tunnel token.
# Do not commit the real token.
TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here

# Public hostname configured in the Cloudflare tunnel dashboard.
PUBLIC_DOMAIN=barckhat.com
PUBLIC_PATH=/oky-docky/
PUBLIC_URL=https://barckhat.com/oky-docky/

# One manual post-Q&A ad. Keep Auto ads disabled in AdSense, then add the
# numeric slot created under Ads > By ad unit > Display ads.
VITE_ADSENSE_CLIENT=ca-pub-8314082563234213
VITE_ADSENSE_SLOT=1815198011

# Created automatically by deploy-pi.sh. Do not put a plaintext password here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=pbkdf2_sha256:iterations:salt:hash
ADMIN_SESSION_SECRET=random-session-secret
ADMIN_COOKIE_SECURE=1
